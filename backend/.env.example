NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080
JWT_SECRET=please-change-this-in-production
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=chat
DB_PASSWORD=chat_password
DB_DATABASE=chat_app
DB_SYNCHRONIZE=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=chat-files
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:9000/chat-files
FILE_MAX_SIZE_MB=20
